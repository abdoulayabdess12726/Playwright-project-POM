{
  "name": "projet-pom-saucedemo",
  "version": "1.0.0",
  "description": "Projet Playwright TypeScript — Pattern POM sur saucedemo.com",
  "scripts": {
    "test": "npx playwright test --project=chromium",
    "test:headed": "npx playwright test --project=chromium --headed",
    "test:debug": "npx playwright test --project=chromium --debug",
    "test:bdd": "npx bddgen && npx playwright test --project=bdd:chromium",
    "test:bdd:headed": "npx bddgen && npx playwright test --project=bdd:chromium --headed",
    "report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "playwright-bdd": "^8.5.0"
  }
}
